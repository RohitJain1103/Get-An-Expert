{
  "name": "get-an-expert-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Get An Expert relay — open-source signaling server. Handles session discovery, WebRTC signaling, authentication, and session metadata. Never sees file contents, terminal output, or browser data; after the WebRTC handshake all data is peer-to-peer. Self-hostable.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "get-an-expert-relay": "dist/index.js"
  },
  "exports": {
    ".": "./src/server.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "pg": "^8.22.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@get-an-expert/core": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
