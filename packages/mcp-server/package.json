{
  "name": "get-an-expert-mcp",
  "version": "0.4.1",
  "description": "Stuck in your AI coding session? Get An Expert connects you with a real human expert — with your explicit consent, it opens a live chat where an expert joins you and watches your real attempts (relayed from your session) until you're unstuck.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "expert",
    "help",
    "claude-code",
    "codex",
    "coding-assistant"
  ],
  "license": "MIT",
  "author": "Get An Expert",
  "homepage": "https://get-an-expert.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RohitJain1103/Get-An-Expert.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/RohitJain1103/Get-An-Expert/issues"
  },
  "type": "module",
  "bin": {
    "get-an-expert-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "devDependencies": {
    "@get-an-expert/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.19.43",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
