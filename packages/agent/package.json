{
  "name": "get-an-expert-agent",
  "version": "1.0.1",
  "description": "Get An Expert agent — on-demand expert assistance where the expert works directly on your machine through scoped, consent-based access. Runs as an MCP server inside Claude Code, Codex, Cursor, or Windsurf.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "expert",
    "pair-programming",
    "remote-assistance",
    "claude-code",
    "codex",
    "cursor",
    "windsurf"
  ],
  "license": "MIT",
  "homepage": "https://github.com/RohitJain1103/Get-An-Expert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RohitJain1103/Get-An-Expert.git",
    "directory": "packages/agent"
  },
  "type": "module",
  "bin": {
    "get-an-expert-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && pnpm build:ui",
    "build:ui": "vite build --config vite.ui.config.ts",
    "dev": "tsx src/index.ts",
    "demo": "tsx examples/local-demo.ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ignore": "^7.0.6",
    "node-datachannel": "^0.32.3",
    "node-pty": "^1.1.0",
    "playwright-core": "^1.61.1",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@get-an-expert/core": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "get-an-expert-relay": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
