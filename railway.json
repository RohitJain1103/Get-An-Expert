{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/relay/Dockerfile",
    "watchPatterns": [
      "apps/relay/**",
      "apps/dashboard/**",
      "pnpm-lock.yaml",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
